# ============================================
# LETUS Platform — Firebase 환경변수
# ============================================
# 이 파일을 복사하여 .env.local 파일을 만드세요:
#   1. 이 파일과 같은 위치에 .env.local 파일 생성
#   2. 아래 값들을 Firebase Console에서 복사한 실제 값으로 교체
#
# Firebase Console > 프로젝트 설정 > 일반 > 내 앱 > SDK 설정 및 구성
# ============================================

# Firebase Client SDK (공개 키 — 프론트엔드에서 사용)
NEXT_PUBLIC_FIREBASE_API_KEY=여기에_API_KEY_입력
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=여기에_프로젝트ID.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=여기에_프로젝트ID_입력
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=여기에_프로젝트ID.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=여기에_SENDER_ID_입력
NEXT_PUBLIC_FIREBASE_APP_ID=여기에_APP_ID_입력

# 관리자 비밀번호
ADMIN_PASSWORD=letus2024
